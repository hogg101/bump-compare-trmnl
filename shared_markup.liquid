}

.bump-compare-shell--half-vertical .week-number {
  font: italic 700 1.85rem/1 "Times New Roman", serif;
}

.bump-compare-shell--half-vertical .trimester-display {
  font: 900 0.875rem/1 "Arial Black", "Helvetica Neue", sans-serif;
}

.bump-compare-shell--half-vertical .icon-container {
