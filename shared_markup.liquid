{% comment %} Get settings with defaults (support multiple TRMNL field shapes) {% endcomment %}
{% assign custom_fields = trmnl.plugin_settings.custom_fields_values %}
{% assign locale = custom_fields.locale | default: trmnl.plugin_settings.locale | default: trmnl.plugin_settings.custom_fields.locale | default: "en-GB" %}
{% assign units = custom_fields.units | default: trmnl.plugin_settings.units | default: trmnl.plugin_settings.custom_fields.units | default: "metric" %}
{% if units == "auto" %}
  {% if locale == "en-US" %}
    {% assign units = "imperial" %}
  {% else %}
    {% assign units = "metric" %}
  {% endif %}
{% endif %}

{% comment %} Resolve due date {% endcomment %}
{% assign due_date_str = custom_fields.due_date | default: trmnl.plugin_settings.due_date | default: trmnl.plugin_settings.custom_fields.due_date %}

{% template bump_compare_markup %}
  {% assign week_title_class = "title title--xlarge" %}
  {% assign comparator_title_class = "title title--large" %}
  {% assign trimester_class = "label" %}
  {% assign size_class = "label" %}
  {% assign progress_bar_class = "progress-bar progress-bar--base" %}
  {% if shell_modifier contains "half-horizontal" %}
    {% assign week_title_class = "title" %}
    {% assign comparator_title_class = "title title--small" %}
    {% assign trimester_class = "label label--small" %}
    {% assign size_class = "value value--xxsmall" %}
    {% assign progress_bar_class = "progress-bar progress-bar--xsmall" %}
  {% elsif shell_modifier contains "half-vertical" %}
    {% assign week_title_class = "title title--large" %}
    {% assign comparator_title_class = "title" %}
    {% assign trimester_class = "label label--small" %}
    {% assign size_class = "value value--xxsmall" %}
    {% assign progress_bar_class = "progress-bar progress-bar--small" %}
  {% elsif shell_modifier contains "quadrant" %}
    {% assign week_title_class = "title title--small" %}
    {% assign comparator_title_class = "title title--small" %}
    {% assign trimester_class = "label label--small" %}
    {% assign size_class = "value value--xxsmall" %}
    {% assign progress_bar_class = "progress-bar progress-bar--xsmall" %}
  {% endif %}

  <div class="layout layout--col layout--center bump-compare{% if shell_modifier %} {{ shell_modifier }}{% endif %}{% if viewport_modifier %} {{ viewport_modifier }}{% endif %}" data-due-date="{{ due_date_str }}" data-locale="{{ locale }}" data-units="{{ units }}" data-weeks='{{ weeks_data | json }}'>
    <div class="bump-compare__body">
      <div class="bump-compare__week">
        <span class="{{ week_title_class }}">Week <span id="current-week">--</span></span>
        <span class="{{ trimester_class }}" id="trimester-display">--</span>
      </div>
      <div class="bump-compare__comparator">
        <div class="bump-compare__icon">
          <img id="comparator-icon" class="image image--contain 1bit:image-dither 2bit:image-dither" src="{{ icon_base_url }}/microscope.png" alt="" hidden />
        </div>
        <span class="{{ comparator_title_class }} bump-compare__name" id="comparator-name" data-clamp="1">--</span>
        <span class="description bump-compare__blurb" id="comparator-blurb" data-clamp="2">--</span>
        <span class="{{ size_class }} bump-compare__size" id="comparator-size" data-clamp="1">--</span>
      </div>
      <div class="{{ progress_bar_class }} bump-progress">
        <div class="content">
          <span class="label label--small">Progress</span>
          <span class="value value--xxsmall" id="progress-text">--%</span>
        </div>
        <div class="track">
          <progress id="progress-fill" max="100" value="0" aria-label="Pregnancy progress"></progress>
        </div>
      </div>
    </div>
  </div>
  <div class="title_bar">
    <span class="title">Bump Compare</span>
    <span class="instance" id="title-week">Week --</span>
  </div>
{% endtemplate %}

<style>
.bump-compare {
  --bump-gap: 0.5rem;
  --bump-icon-size: 170px;
  display: grid;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  text-align: center;
}

.bump-compare__body {
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  align-items: center;
  justify-items: center;
  gap: var(--bump-gap);
  width: 100%;
  height: 100%;
  min-height: 0;
}

.bump-compare__week {
  display: grid;
  justify-items: center;
  gap: 0.2rem;
  width: 100%;
}

.bump-compare__comparator {
  display: grid;
  grid-template-rows: auto auto auto auto;
  align-items: center;
  justify-items: center;
  gap: 0.25rem;
  min-height: 0;
  width: 100%;
}

.bump-compare__icon {
  display: grid;
  place-items: center;
  width: var(--bump-icon-size);
  height: var(--bump-icon-size);
  overflow: visible;
}

.bump-compare__icon img.image {
  display: block;
  width: var(--bump-icon-size) !important;
  height: var(--bump-icon-size) !important;
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  object-position: center;
}

.bump-compare__name,
.bump-compare__blurb,
.bump-compare__size {
  max-width: 95%;
}

.bump-compare__size {
  white-space: nowrap;
}

.bump-progress {
  width: 100%;
  max-width: 430px;
}

.bump-progress .content {
  width: 100%;
}

.bump-progress .track {
  width: 100%;
  overflow: hidden;
}

.bump-progress progress {
  display: block;
  width: 100%;
  height: 100%;
  appearance: none;
  -webkit-appearance: none;
  border: 0;
  background: transparent;
}

.bump-progress progress::-webkit-progress-bar {
  background: transparent;
}

.bump-progress progress::-webkit-progress-value {
  background: #000;
}

.bump-progress progress::-moz-progress-bar {
  background: #000;
}

.bump-compare-shell--full {
  --bump-gap: 0.6rem;
  --bump-icon-size: 180px;
}

.bump-compare-shell--full .bump-compare__comparator {
  gap: 0.35rem;
}

/* Half horizontal and half vertical shared compact base */
.bump-compare-shell--compact {
  --bump-gap: 0.3rem;
  --bump-icon-size: 96px;
}

.bump-compare-shell--compact .bump-progress .content {
  display: none;
}

/* Half horizontal specific tweaks */
.bump-compare-shell--half-horizontal {
  --bump-gap: 0.18rem;
  --bump-icon-size: 72px;
}

.bump-compare-shell--half-horizontal .bump-compare__comparator {
  gap: 0.08rem;
}

.bump-compare-shell--half-horizontal .bump-compare__icon {
  overflow: hidden;
}

.bump-compare-shell--half-horizontal .bump-compare__blurb {
  display: none;
}

/* Half vertical specific tweaks */
.bump-compare-shell--half-vertical {
  --bump-icon-size: 112px;
}

/* Quadrant */
.bump-compare-shell--quadrant {
  --bump-gap: 0.12rem;
  --bump-icon-size: 52px;
}

.bump-compare-shell--quadrant .bump-compare__icon {
  overflow: hidden;
}

.bump-compare-shell--quadrant .bump-compare__blurb,
.bump-compare-shell--quadrant .bump-progress {
  display: none;
}
</style>

<script>
(function() {
  function initBumpCompare() {
    const container = document.querySelector('.bump-compare');
    if (!container) return;

    const dueDateStr = (container.dataset.dueDate || '').trim();
    const locale = container.dataset.locale || 'en-GB';
    const units = container.dataset.units || 'metric';
    const weeksData = JSON.parse(container.dataset.weeks || '[]');
    const currentWeekEl = document.getElementById('current-week');
    const titleWeekEl = document.getElementById('title-week');
    const trimesterEl = document.getElementById('trimester-display');
    const progressEl = document.getElementById('progress-fill');
    const progressTextEl = document.getElementById('progress-text');
    const comparatorNameEl = document.getElementById('comparator-name');
    const comparatorBlurbEl = document.getElementById('comparator-blurb');
    const comparatorSizeEl = document.getElementById('comparator-size');
    const us_name_aliases = {
      'Aubergine': 'Eggplant',
      'Courgette': 'Zucchini',
      'Marrow': 'Summer squash',
      'Swede': 'Rutabaga',
      'Cantaloupe melon': 'Cantaloupe',
      'Zuccini': 'Zucchini'
    };

    if (!dueDateStr) {
      currentWeekEl.textContent = '?';
      titleWeekEl.textContent = 'Set due date';
      comparatorNameEl.textContent = 'Set due date';
      comparatorSizeEl.textContent = 'Add YYYY-MM-DD in settings';
      return;
    }

    // Parse due date
    const dueDate = new Date(dueDateStr + 'T00:00:00');
    if (isNaN(dueDate.getTime())) {
      currentWeekEl.textContent = '?';
      titleWeekEl.textContent = 'Invalid date';
      comparatorNameEl.textContent = 'Invalid date';
      return;
    }

    // Calculate gestational week: week = clamp(floor((280 - days_to_due) / 7), 0, 40)
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const daysToDue = Math.ceil((dueDate - today) / (1000 * 60 * 60 * 24));

    if (daysToDue > 280) {
      currentWeekEl.textContent = '!';
      titleWeekEl.textContent = 'Due date too far';
      comparatorNameEl.textContent = 'Due date too far';
      comparatorSizeEl.textContent = 'Date must be within 9 months';
      return;
    }

    const week = Math.max(0, Math.min(40, Math.floor((280 - daysToDue) / 7)));

    let comparator = weeksData.find(function(entry) {
      return entry.week === week;
    });

    if (!comparator) {
      comparator = weeksData[Math.max(0, Math.min(weeksData.length - 1, week))] || weeksData[0];
    }

    // Display week
    currentWeekEl.textContent = week;
    titleWeekEl.textContent = 'Week ' + week;

    // Determine and display trimester
    let trimester;
    if (week <= 12) {
      trimester = 'First Trimester';
    } else if (week <= 28) {
      trimester = 'Second Trimester';
    } else {
      trimester = 'Third Trimester';
    }
    trimesterEl.textContent = trimester;

    // Update progress bar
    const progressPercent = Math.max(0, Math.min(100, ((280 - daysToDue) / 280) * 100));
    progressEl.value = progressPercent;
    progressTextEl.textContent = Math.round(progressPercent) + '%';

    // Display comparator name
    const localized_name = comparator.name[locale] || comparator.name['en-GB'] || '';
    const gb_name = comparator.name['en-GB'] || '';
    const name = locale === 'en-US'
      ? (us_name_aliases[localized_name] || us_name_aliases[gb_name] || localized_name)
      : localized_name;
    comparatorNameEl.textContent = name;
    const blurb = comparator.blurb && (comparator.blurb[locale] || comparator.blurb['en-GB']) || '';
    comparatorBlurbEl.textContent = blurb;

    // Convert and display size
    const compactSize = container.classList.contains('bump-compare--compact') || container.classList.contains('bump-compare--quadrant');
    let lengthStr;
    let weightStr;
    let compactLengthStr;
    let compactWeightStr;
    if (units === 'imperial') {
      const lengthIn = (comparator.length_mm / 25.4).toFixed(1);
      const weightOz = comparator.weight_g / 28.35;
      if (weightOz >= 16) {
        const lbs = Math.floor(weightOz / 16);
        const oz = Math.round(weightOz % 16);
        weightStr = lbs + ' lb ' + oz + ' oz';
        compactWeightStr = lbs + 'lb' + oz + 'oz';
      } else {
        weightStr = weightOz.toFixed(1) + ' oz';
        compactWeightStr = weightOz.toFixed(1) + 'oz';
      }
      lengthStr = lengthIn + ' in';
      compactLengthStr = lengthIn + 'in';
    } else {
      if (comparator.length_mm > 100) {
        lengthStr = (comparator.length_mm / 10).toFixed(1) + ' cm';
        compactLengthStr = (comparator.length_mm / 10).toFixed(1) + 'cm';
      } else {
        lengthStr = comparator.length_mm + ' mm';
        compactLengthStr = comparator.length_mm + 'mm';
      }
      if (comparator.weight_g >= 1000) {
        weightStr = (comparator.weight_g / 1000).toFixed(1) + ' kg';
        compactWeightStr = (comparator.weight_g / 1000).toFixed(1) + 'kg';
      } else {
        weightStr = comparator.weight_g + ' g';
        compactWeightStr = comparator.weight_g + 'g';
      }
    }

    comparatorSizeEl.textContent = compactSize
      ? compactLengthStr + '/' + compactWeightStr
      : lengthStr + ', ' + weightStr;

    // Show icon if available
    const iconEl = document.getElementById('comparator-icon');
    if (comparator.icon) {
      iconEl.src = '{{ icon_base_url }}/' + comparator.icon;
      iconEl.alt = name;
      iconEl.removeAttribute('hidden');
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBumpCompare);
  } else {
    initBumpCompare();
  }
})();
</script>
