{% comment %} Get settings with defaults (support multiple TRMNL field shapes) {% endcomment %}
{% assign custom_fields = trmnl.plugin_settings.custom_fields_values %}
{% assign locale = custom_fields.locale | default: trmnl.plugin_settings.locale | default: trmnl.plugin_settings.custom_fields.locale | default: "en-GB" %}
{% assign units = custom_fields.units | default: trmnl.plugin_settings.units | default: trmnl.plugin_settings.custom_fields.units | default: "metric" %}
{% if units == "auto" %}
  {% if locale == "en-US" %}
    {% assign units = "imperial" %}
  {% else %}
    {% assign units = "metric" %}
  {% endif %}
{% endif %}

{% comment %} Resolve due date {% endcomment %}
{% assign due_date_str = custom_fields.due_date | default: trmnl.plugin_settings.due_date | default: trmnl.plugin_settings.custom_fields.due_date %}

{% template bump_compare_markup %}
  <div class="bump-compare-shell{% if shell_modifier %} {{ shell_modifier }}{% endif %}">
    <div class="title_bar">
      <span class="title">Bump Compare</span>
    </div>
    <div class="bump-compare{% if viewport_modifier %} {{ viewport_modifier }}{% endif %}" data-due-date="{{ due_date_str }}" data-locale="{{ locale }}" data-units="{{ units }}" data-weeks='{{ weeks_data | json }}'>
      <div class="week-display">
        <div class="week-number">Week <span id="current-week">--</span></div>
        <div class="trimester-display" id="trimester-display">--</div>
      </div>
      <div class="comparator">
        <div class="icon-container">
          <img id="comparator-icon" class="image image--contain 1bit:image-dither 2bit:image-dither" src="{{ icon_base_url }}/microscope.png" alt="" hidden />
        </div>
        <div class="comparator-name" id="comparator-name">--</div>
        <div class="comparator-blurb" id="comparator-blurb">--</div>
        <div class="comparator-size" id="comparator-size">--</div>
      </div>
      <div class="progress-container">
        <progress id="progress-fill" max="100" value="0"></progress>
        <div class="progress-text" id="progress-text">--%</div>
      </div>
    </div>
  </div>
{% endtemplate %}

<style>
.bump-compare-shell {
  --v-gap: 0.25rem;
  display: grid;
  grid-template-rows: auto 1fr;
  align-items: start;
  justify-items: center;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  gap: 0.25rem;
}

.title_bar {
  width: 97%;
  display: grid;
  place-items: center;
}

.title_bar .title {
  font: 900 0.92rem/1 "Arial Black", "Helvetica Neue", sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  white-space: nowrap;
}

.bump-compare {
  width: 97%;
  height: 100%;
  display: grid;
  grid-template-rows: auto auto auto;
  align-content: space-between;
  align-items: center;
  gap: var(--v-gap);
}

.week-display {
  display: grid;
  gap: var(--v-gap);
  justify-items: center;
  width: 100%;
}

.week-display::before {
  content: "";
  display: block;
  height: 0.18rem;
}

.week-number {
  font: italic 700 2.2rem/1 "Times New Roman", serif;
}

.trimester-display {
  font: 900 0.98rem/1 "Arial Black", "Helvetica Neue", sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.comparator {
  display: grid;
  grid-template-rows: auto auto auto auto;
  align-items: center;
  justify-items: center;
  gap: var(--v-gap);
  min-height: 0;
}

.icon-container {
  display: grid;
  place-items: center;
  width: 170px;
  height: 170px;
  overflow: hidden;
}

.icon-container img {
  max-width: 100%;
  max-height: 100%;
}

.comparator-name {
  font: 900 1.35rem/1 "Arial Black", "Helvetica Neue", sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.comparator-blurb {
  font: italic 400 0.95rem/1.2 "Times New Roman", serif;
  max-width: 95%;
}

.comparator-size {
  font: 400 0.9rem/1 "Courier New", monospace;
  color: #444;
}

.progress-container {
  width: 100%;
  display: grid;
  gap: var(--v-gap);
  align-items: center;
}

.progress-container progress {
  width: 100%;
  height: 18px;
  appearance: none;
  -webkit-appearance: none;
  border: 2px solid #000;
  background: #fff;
  overflow: hidden;
  box-shadow: 2px 2px 0px #888;
}

.progress-container progress::-webkit-progress-bar {
  background: #fff;
}

.progress-container progress::-webkit-progress-value {
  background: linear-gradient(
    to bottom,
    #8c8c8c 0%,
    #8c8c8c 33%,
    #4d4d4d 33%,
    #4d4d4d 66%,
    #000 66%,
    #000 100%
  );
}

.progress-container progress::-moz-progress-bar {
  background: linear-gradient(
    to bottom,
    #8c8c8c 0%,
    #8c8c8c 33%,
    #4d4d4d 33%,
    #4d4d4d 66%,
    #000 66%,
    #000 100%
  );
}

.progress-text {
  font: 400 0.8rem/1 "Courier New", monospace;
  color: #444;
  justify-self: center;
}

/* Half horizontal and half vertical shared compact base */
.bump-compare-shell--compact .title_bar .title {
