  height: 118px;
}

.bump-compare-shell--half-vertical .comparator-name {
  font: 900 1.1rem/1 "Arial Black", "Helvetica Neue", sans-serif;
}

.bump-compare-shell--half-vertical .comparator-blurb {
  font: italic 400 0.78rem/1.2 "Times New Roman", serif;
}

.bump-compare-shell--half-vertical .comparator-size {
  font: 400 0.8rem/1 "Courier New", monospace;
}

.bump-compare-shell--half-vertical .progress-text {
  font: 400 0.72rem/1 "Courier New", monospace;
}

/* Quadrant */
.bump-compare-shell--quadrant .title_bar .title {
  font: 900 0.65rem/1 "Arial Black", "Helvetica Neue", sans-serif;
}

.bump-compare-shell--quadrant {
  --v-gap: 0.12rem;
}

.bump-compare-shell--quadrant .week-number {
  font: italic 700 1.15rem/1 "Times New Roman", serif;
}

.bump-compare-shell--quadrant .trimester-display {
  font: 900 0.625rem/1 "Arial Black", "Helvetica Neue", sans-serif;
}

.bump-compare-shell--quadrant .icon-container {
  width: 64px;
  height: 64px;
}

.bump-compare-shell--quadrant .comparator-name {
  font: 600 0.875rem/1 "Arial Black", "Helvetica Neue", sans-serif;
}

.bump-compare-shell--quadrant .comparator-blurb {
  font: italic 400 0.56rem/1.15 "Times New Roman", serif;
  max-width: 97%;
}

.bump-compare-shell--quadrant .comparator-size {
  font: 400 0.625rem/1 "Courier New", monospace;
}

.bump-compare-shell--quadrant .progress-container progress {
